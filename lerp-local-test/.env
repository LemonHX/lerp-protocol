# Relay configuration for local testing
# Used by: cargo run -p lerp-relay

# 32-byte shared secret (hex). Must match relay_sec_hex in both daemon configs.
RELAY_SECRET=c0ffee00c0ffee00c0ffee00c0ffee00c0ffee00c0ffee00c0ffee00c0ffee00

# TLS certificate and key (generated by setup script).
RELAY_CERT=./certs/cert.pem
RELAY_KEY=./certs/key.pem

# Listen address.
RELAY_BIND=127.0.0.1:4433

# How long to wait for the second peer to connect before timing out (seconds).
RELAY_PAIR_TIMEOUT=30

# Log level (trace | debug | info | warn | error).
RUST_LOG=debug
